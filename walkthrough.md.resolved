        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]"
          x-data="{
            rows: {!! isset($article) && $article->vocabulary_list
              ? json_encode(collect($article->vocabulary_list)->map(fn($v) => ['kanji' => $v['kata'] ?? '', 'furigana' => $v['romaji'] ?? '', 'meaning' => $v['arti'] ?? '', 'example' => $v['contoh'] ?? ''])->toArray())
              : json_encode([['kanji' => '', 'furigana' => '', 'meaning' => '', 'example' => '']]) !!},
            addRow() {
              this.rows.push({ kanji: '', furigana: '', meaning: '', example: '' });
            },
            removeRow(index) {
              if (this.rows.length > 1) this.rows.splice(index, 1);
            }
          }">
          <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-800">
            <h3 class="text-base font-medium text-gray-800 dark:text-white/90">📋 Tabel Kosakata / Referensi</h3>
