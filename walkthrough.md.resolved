        {{-- 🟡 5. AUTO SLUG: Judul otomatis jadi slug --}}
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]"
          x-data="{
            title: '{{ old('title', isset($article) ? addslashes($article->title) : '') }}',
            slug: '{{ old('slug', isset($article) ? $article->slug : '') }}',
            autoSlug: {{ isset($article) ? 'false' : 'true' }},
            generateSlug(text) {
              return text.toLowerCase()
                .replace(/[àáâãäå]/g, 'a').replace(/[èéêë]/g, 'e').replace(/[ìíîï]/g, 'i')
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
            }
          }">
          <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-800">
            <h3 class="text-base font-medium text-gray-800 dark:text-white/90">📌 Informasi Dasar</h3>
